# macOS Code-Signing & Notarisierung für `npm run tauri build`.
#
# Vorlage. Zum Nutzen:
#   cp notarize.env.example .env.notarize
# und APPLE_ID + APPLE_PASSWORD eintragen. Die Datei .env.notarize ist
# über .gitignore (.env.*) ausgeschlossen und darf NIE committet werden.
#
# Build mit Signierung + Notarisierung:
#   set -a && source .env.notarize && set +a && npm run tauri build
#
# Tauri signiert dann mit der Developer-ID, lädt die App zur Notarisierung
# hoch und "stapled" das Ticket automatisch ins .dmg/.app.

APPLE_SIGNING_IDENTITY="Developer ID Application: Jan Ralf Stuerkat (C5K97RA3L8)"
APPLE_TEAM_ID="C5K97RA3L8"

# Apple-ID-E-Mail des Developer-Accounts:
APPLE_ID="j.stuerkat@icloud.com"

# App-spezifisches Passwort von appleid.apple.com (NICHT das normale Passwort):
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
